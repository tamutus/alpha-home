#!/usr/bin/env bash
# pre-commit — validate JSON files and writing directory structure before commit

set -euo pipefail

errors=0
WRITING_DATA="src/lib/writing-data.js"

# ── Validate staged JSON files ──
staged_json=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.json$' || true)

if [ -n "$staged_json" ]; then
    for file in $staged_json; do
        if [ ! -f "$file" ]; then
            continue
        fi
        if ! python3 -m json.tool "$file" > /dev/null 2>&1; then
            echo "❌ Invalid JSON: $file"
            python3 -m json.tool "$file" 2>&1 | tail -3
            errors=$((errors + 1))
        fi
    done
fi

# ── Validate writing/ directory structure ──
# Prevents the BUILD ERROR class (unregistered route subdirectory).
# Allows journal-* directories AND directories matching a slug in writing-data.js.
staged_writing=$(git diff --cached --name-only --diff-filter=ACM | grep '^src/routes/writing/' || true)

if [ -n "$staged_writing" ]; then
    # Extract unique immediate subdirectory names under writing/
    staged_dirs=$(echo "$staged_writing" | \
        sed -n 's|^src/routes/writing/\([^/]*\)/.*|\1|p' | \
        sort -u)

    # Pre-compute allowed non-journal slugs from writing-data.js (framework essays, etc.)
    if [ -f "$WRITING_DATA" ]; then
        wd_slugs=$(grep -oP 'slug:\s*"\K[^"]+' "$WRITING_DATA" | sort -u)
    else
        wd_slugs=""
    fi

    bad_dirs=""
    while IFS= read -r dir; do
        case "$dir" in journal-*) continue ;; esac
        # Allow if it matches a slug in writing-data.js
        if echo "$wd_slugs" | grep -qFx "$dir"; then
            continue
        fi
        bad_dirs="$bad_dirs$dir"$'\n'
    done <<< "$staged_dirs"

    if [ -n "$bad_dirs" ]; then
        echo "❌ Unexpected subdirectory in src/routes/writing/ — not 'journal-*' or a registered slug:"
        echo "$bad_dirs" | sed 's/^/   /'
        errors=$((errors + 1))
    fi

    # Also verify that +page.md or +page.svelte exists in each directory with staged content
    for dir in $(echo "$staged_writing" | \
        sed -n 's|^src/routes/writing/\([^/]*\)/.*|\1|p' | \
        sort -u); do
        page_file="src/routes/writing/$dir/+page.md"
        page_svelte="src/routes/writing/$dir/+page.svelte"
        if [ ! -f "$page_file" ] && [ ! -f "$page_svelte" ]; then
            echo "❌ Writing directory '$dir' has staged content but no +page.md or +page.svelte"
            errors=$((errors + 1))
        fi
    done
fi

if [ "$errors" -gt 0 ]; then
    echo ""
    echo "Found $errors issue(s). Fix before committing."
    exit 1
fi

exit 0
